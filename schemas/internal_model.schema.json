{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/ecad-agent/internal_model.schema.json",
  "title": "ECAD Agent Internal Model",
  "type": "object",
  "required": ["schema_version", "project", "components", "nets"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "project": {
      "type": "object",
      "required": ["name", "source_format"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source_format": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "nets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/net"
      }
    },
    "wires": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/wire"
      },
      "default": []
    },
    "labels": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/label"
      },
      "default": []
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      },
      "default": []
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": ["ref", "type", "pins"],
      "properties": {
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "footprint": {
          "type": "string"
        },
        "source_id": {
          "type": "string"
        },
        "pins": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pin"
          }
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "pin": {
      "type": "object",
      "required": ["number"],
      "properties": {
        "number": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "net": {
          "type": "string"
        },
        "electrical_type": {
          "type": "string"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "net": {
      "type": "object",
      "required": ["name", "nodes"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[^.]+\\.[^.]+$"
          }
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "wire": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": {
          "$ref": "#/$defs/point"
        },
        "end": {
          "$ref": "#/$defs/point"
        },
        "net": {
          "type": "string"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "label": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string"
        },
        "net": {
          "type": "string"
        },
        "at": {
          "$ref": "#/$defs/point"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "warning": {
      "type": "object",
      "required": ["code", "message", "severity"],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "severity": {
          "enum": ["info", "warning", "error"]
        },
        "subject": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "point": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "number"
      }
    }
  }
}
